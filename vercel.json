{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm run install:all",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist/resume-scanner-frontend",
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "backend/**"
      ],
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "handle": "filesystem"
    }
  ]
}